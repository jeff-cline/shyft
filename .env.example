# Booking iframe fallback (Krystalore can override via admin Settings)
BOOKING_IFRAME_URL=https://krystalore.com/book

# Cross-domain URLs (leave blank locally — defaults to /doctor and /mastery paths)
# In production set these to the real hosts so cross-site links work
# NEXT_PUBLIC_DOCTOR_URL=https://shyftdoctor.com
# NEXT_PUBLIC_MASTERY_URL=https://shyftmastery.com

# Iteration 2 — Auth + DB
# AUTH_SECRET=
# DATABASE_URL="file:./prisma/dev.db"

# Iteration 4 — Stripe (admin sets via Settings UI; env keys are only for local testing)
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=

# One-time seed admin password — only read on first boot
# SEED_ADMIN_PASSWORD=
